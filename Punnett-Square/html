        "dorso", "borde", "cola", "cuerpo", "color", "aleta",
        "scales", "scale", "seeds", "seed", "coat", "petals", "petal", "wings", "wing", "fruit",
        "kernels", "kernel", "ears", "ear", "flowers", "flower", "stems", "stem", "back", "edge",
        "tail", "body", "color", "fin",
        "écailles", "écaille", "graines", "graine", "pelage", "pétales", "pétale", "ailes", "aile",
        "fruits", "fruit", "grains", "grain", "oreilles", "oreille", "fleurs", "fleur", "tiges",
        "tige", "dos", "bord", "queue", "corps", "couleur", "nageoire"
      ]);
      const words = phrase.split(/\s+/).filter((word) => {
        const normalized = word.toLocaleLowerCase().replace(/[.,:;()]/g, "");
        return !removable.has(normalized);
      });
      return words.length ? words.join(" ") : phrase;
    }

    function compactPhenotypeLabelFromKey(key, genes) {
      if (genes.length === 1) return phenotypeLabelFromKey(key, genes);
      return genes.map((g, i) => compactPhrase(key[i] === "D" ? g.dominant : g.recessive)).join(ui().plus);
    }

    function parentPhenotype(genotype, ex) {
      return phenotypeLabelFromKey(phenotypeKey(genotype, ex.genes), ex.genes);
    }

    function expectedData(ex) {
      const ga = gametes(ex.parents[0], ex.genes);
      const gb = gametes(ex.parents[1], ex.genes);
      const cells = [];
      const genotypeCounts = {};
      const phenotypeCounts = {};
      ga.forEach((a) => gb.forEach((b) => {
        const child = combineGametes(a, b, ex.genes);
        cells.push(child);
        genotypeCounts[child] = (genotypeCounts[child] || 0) + 1;
        const pk = phenotypeKey(child, ex.genes);
        phenotypeCounts[pk] = (phenotypeCounts[pk] || 0) + 1;
      }));
      const total = cells.length;
      const genotypePercents = Object.fromEntries(Object.keys(genotypeCounts).sort().map((k) => [k, genotypeCounts[k] * 100 / total]));
      const phenotypePercents = Object.fromEntries(Object.keys(phenotypeCounts).sort().map((k) => [k, phenotypeCounts[k] * 100 / total]));
      return { ga, gb, cells, genotypeCounts, phenotypeCounts, genotypePercents, phenotypePercents, total };
    }

    function percentText(n) {
      return Number.isInteger(n) ? String(n) : n.toFixed(1).replace(".", ",");
    }

    function normalizePercent(value) {
      return Number(String(value).trim().replace("%", "").replace(",", "."));
    }

    function allPossibleGenotypes(genes) {
      const perGene = genes.map((g) => [g.upper + g.upper, g.upper + g.lower, g.lower + g.lower]);
      return cartesian(perGene);
    }

    function allPhenotypeKeys(genes) {
      return cartesian(genes.map(() => ["D", "R"]));
    }

    function renderPunnett(ex, data) {
      const grid = $("punnett");
      grid.className = `punnett ${ex.genes.length === 1 ? "mono" : "di"}`;
      const labelWidth = ex.genes.length === 1 ? "clamp(76px, 9vw, 126px)" : "clamp(66px, 7vw, 104px)";
      grid.style.gridTemplateColumns = `${labelWidth} repeat(${data.gb.length}, minmax(0, 1fr))`;
      grid.style.gridTemplateRows = `repeat(${data.ga.length + 1}, minmax(0, 1fr))`;
      grid.innerHTML = "";
      const corner = document.createElement("div");
      corner.className = "p-cell corner";
      corner.innerHTML = ui().gametesCorner;
      grid.appendChild(corner);
      data.gb.forEach((g) => {
        const div = document.createElement("div");
        div.className = "p-cell top-gamete";
        div.textContent = g;
        grid.appendChild(div);
      });
      data.ga.forEach((ag) => {
        const side = document.createElement("div");
        side.className = "p-cell side-gamete";
        side.textContent = ag;
        grid.appendChild(side);
        data.gb.forEach((bg) => {
          const div = document.createElement("div");
          div.className = "p-cell answer-cell";
          const input = document.createElement("input");
          input.placeholder = ui().write;
          input.autocomplete = "off";
          input.dataset.answer = combineGametes(ag, bg, ex.genes);
          input.addEventListener("input", () => div.classList.remove("ok", "no"));
          div.appendChild(input);
          grid.appendChild(div);
        });
      });
    }

    function renderResults(ex, textEx) {
      const t = ui();
      const genotypeWrap = $("genotypeResults");
      genotypeWrap.innerHTML = "";
      allPossibleGenotypes(ex.genes).forEach((gt) => {
        const row = document.createElement("div");
        row.className = "result-row";
        row.title = `${t.genotype} ${gt}`;
        row.innerHTML = `<label>${gt}</label><span><input inputmode="decimal" data-kind="geno" data-key="${gt}" aria-label="${t.genotype} ${gt}"> %</span>`;
        genotypeWrap.appendChild(row);
      });
      const phenotypeWrap = $("phenotypeResults");
      phenotypeWrap.innerHTML = "";
      allPhenotypeKeys(ex.genes).forEach((pk) => {
        const label = phenotypeLabelFromKey(pk, textEx.genes);
        const displayLabel = compactPhenotypeLabelFromKey(pk, textEx.genes);
        const row = document.createElement("div");
        row.className = "result-row";
        const pattern = pk.split("").map((v, i) => v === "D" ? `${ex.genes[i].upper}_` : `${ex.genes[i].lower}${ex.genes[i].lower}`).join(" ");
        row.title = `${label} (${pattern})`;
        row.innerHTML = `<label>${displayLabel} <span class="tiny">(${pattern})</span></label><span><input inputmode="decimal" data-kind="pheno" data-key="${pk}" aria-label="${t.phenotype} ${label}"> %</span>`;
        phenotypeWrap.appendChild(row);
      });
      document.querySelectorAll(".result-row input").forEach((input) => input.addEventListener("input", () => input.closest(".result-row").classList.remove("ok", "no")));
    }

    function setBadge(ex) {
      $("badgeArt").innerHTML = iconSvg(ex.icon, "#fff");
    }

    function alleleNote(ex, parentIndex) {
      if (ex.genes.length === 1) {
        const g = ex.genes[0];
        return parentIndex === 0
          ? `${ui().dominantAllele}: ${g.upper} (${g.dominant})`
          : `${ui().recessiveAllele}: ${g.lower} (${g.recessive})`;
      }
      return ex.genes.map((g) => `${g.upper}/${g.lower}: ${g.dominant} ${ui().versus} ${g.recessive}`).join(" · ");
    }

    function applyStaticText() {
      const t = ui();
      document.documentElement.lang = state.lang;
      $("languageSelect").value = state.lang;
      $("resetBtn").title = t.resetText;
      $("resetBtn").setAttribute("aria-label", t.resetText);
      $("prevBtn").title = t.exercise;
      $("prevBtn").setAttribute("aria-label", t.exercise);
      $("nextBtn").title = t.exercise;
      $("nextBtn").setAttribute("aria-label", t.exercise);
      $("monoTab").textContent = t.mono;
      $("diTab").textContent = t.di;
      $("randomText").textContent = t.random;
      $("parentALabel").textContent = t.parentA;
      $("parentBLabel").textContent = t.parentB;
      document.querySelectorAll(".genoLabel").forEach((label) => label.textContent = t.genotype);
      document.querySelectorAll(".phenoLabel").forEach((label) => label.textContent = t.phenotype);
      document.querySelectorAll(".traitLabel").forEach((label) => label.textContent = t.trait);
      $("punnettTitle").textContent = t.punnettTitle;
      $("resultsTitle").textContent = t.resultsTitle;
      $("genotypesTitle").textContent = t.genotypes;
      $("phenotypesTitle").textContent = t.phenotypes;
      $("checkText").textContent = t.check;
      $("hintText").textContent = t.hint;
      $("modePracticeText").textContent = t.modePractice;
      $("creditText").textContent = t.credit;
      $("creditCloseBtn").setAttribute("aria-label", t.closeCredit);
    }

    function render() {
      const ex = exercises[state.mode][state.index];
      const textEx = localizedExercise(ex);
      const data = expectedData(ex);
      const t = ui();
      state.checked = false;
      applyStaticText();
      $("modeLabel").textContent = state.mode === "mono" ? t.monoPlural : t.diPlural;
      $("monoTab").classList.toggle("active", state.mode === "mono");
      $("diTab").classList.toggle("active", state.mode === "di");
      $("counter").textContent = `${t.exercise} ${state.index + 1} ${t.of} 15`;
      $("title").textContent = textEx.title;
      $("crossLine").innerHTML = `${t.cross}: <strong>${ex.parents[0]} x ${ex.parents[1]}</strong>`;
      $("instructions").textContent = ex.genes.length === 1 ? t.monoInstruction : t.diInstruction;
      setBadge(ex);
      $("artA").innerHTML = organismArt(ex, textEx, ex.parents[0]);
      $("artB").innerHTML = organismArt(ex, textEx, ex.parents[1]);
      $("genoA").textContent = ex.parents[0];
      $("genoB").textContent = ex.parents[1];
      $("phenoA").textContent = parentPhenotype(ex.parents[0], textEx);
      $("phenoB").textContent = parentPhenotype(ex.parents[1], textEx);
      $("traitA").textContent = textEx.trait;
      $("traitB").textContent = textEx.trait;
      $("noteA").textContent = alleleNote(textEx, 0);
      $("noteB").textContent = alleleNote(textEx, 1);
      renderPunnett(ex, data);
      renderResults(ex, textEx);
      $("feedback").className = "feedback";
      $("feedback").textContent = t.feedbackDefault;
      updateProgress();
    }

    function check() {
      const ex = exercises[state.mode][state.index];
      const data = expectedData(ex);
      const t = ui();
      let correctCells = 0;
      document.querySelectorAll(".answer-cell").forEach((cell) => {
        const input = cell.querySelector("input");
        const ok = input.value.trim().toLowerCase() === input.dataset.answer.toLowerCase();
        cell.classList.toggle("ok", ok);
        cell.classList.toggle("no", !ok);
        if (ok) correctCells++;
      });
      let correctPercents = 0;
      let totalPercents = 0;
      document.querySelectorAll(".result-row input").forEach((input) => {
        const isGeno = input.dataset.kind === "geno";
        const expected = isGeno ? (data.genotypePercents[input.dataset.key] || 0) : (data.phenotypePercents[input.dataset.key] || 0);
        const value = normalizePercent(input.value);
        const ok = Number.isFinite(value) && Math.abs(value - expected) <= 0.6;
        input.closest(".result-row").classList.toggle("ok", ok);
        input.closest(".result-row").classList.toggle("no", !ok);
        totalPercents++;
        if (ok) correctPercents++;
      });
      const allOk = correctCells === data.total && correctPercents === totalPercents;
      const fb = $("feedback");
      fb.className = `feedback ${allOk ? "good" : "bad"}`;
      if (allOk) {
        fb.textContent = t.feedbackGood;
        state.solved[state.mode].add(state.index);
      } else {
        fb.textContent = t.feedbackBad(correctCells, data.total, correctPercents, totalPercents);
      }
      updateProgress();
    }

    function hint() {
      const ex = exercises[state.mode][state.index];
      const data = expectedData(ex);
      const t = ui();
      const fb = $("feedback");
      fb.className = "feedback";
      const first = data.cells[0];
      const genoHint = Object.entries(data.genotypePercents).map(([k, v]) => `${k}: ${percentText(v)}%`).join(" · ");
      fb.textContent = t.hintText(data.ga.join(", "), data.gb.join(", "), first, genoHint);
    }

    function resetAnswers() {
      document.querySelectorAll("input").forEach((input) => input.value = "");
      document.querySelectorAll(".ok,.no").forEach((el) => el.classList.remove("ok", "no"));
      $("feedback").className = "feedback";
      $("feedback").textContent = ui().resetText;
    }

    function updateProgress() {
      const total = exercises.mono.length + exercises.di.length;
      const solved = state.solved.mono.size + state.solved.di.size;
      const pct = Math.round((solved / total) * 100);
      $("progressText").textContent = `${ui().progress}: ${pct}%`;
      $("progressBar").style.width = `${pct}%`;
    }

    $("prevBtn").addEventListener("click", () => {
      state.index = (state.index + 14) % 15;
      render();
    });
    $("nextBtn").addEventListener("click", () => {
      state.index = (state.index + 1) % 15;
      render();
    });
    $("randomBtn").addEventListener("click", () => {
      state.index = Math.floor(Math.random() * 15);
      render();
    });
    $("monoTab").addEventListener("click", () => {
      state.mode = "mono";
      state.index = 0;
      render();
    });
    $("diTab").addEventListener("click", () => {
      state.mode = "di";
      state.index = 0;
      render();
    });
    $("checkBtn").addEventListener("click", check);
    $("hintBtn").addEventListener("click", hint);
    $("resetBtn").addEventListener("click", resetAnswers);
    $("languageSelect").addEventListener("change", (event) => {
      state.lang = event.target.value;
      render();
    });
    $("creditCloseBtn").addEventListener("click", () => {
      $("creditFooter").classList.add("hide");
    });

    render();
  </script>
</body>
</html>
