<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Genetics BioLab | Cuadros de Punnett</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23eef6ff'/%3E%3Cpath d='M21 8c23 12 23 36 0 48M43 8C20 20 20 44 43 56' fill='none' stroke='%2300a984' stroke-width='5' stroke-linecap='round'/%3E%3Cpath d='M24 18h16M20 28h24M20 38h24M24 48h16' stroke='%232276f3' stroke-width='4' stroke-linecap='round'/%3E%3C/svg%3E">
  <style>
    :root {
      color-scheme: light;
      --ink: #102657;
      --muted: #60719d;
      --line: #dbe5f6;
      --soft: #f5f8fd;
      --panel: rgba(255,255,255,.9);
      --blue: #2276f3;
      --teal: #00a984;
      --violet: #7c3aed;
      --rose: #ef5da8;
      --amber: #f59e0b;
      --green: #10a15d;
      --bad: #dc3545;
      --good: #07884f;
      --shadow: 0 20px 55px rgba(28, 57, 117, .13);
      --radius: 8px;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * { box-sizing: border-box; }
    html { height: 100%; overflow: hidden; }
    body {
      margin: 0;
      height: 100%;
      min-height: 100dvh;
      overflow: hidden;
      color: var(--ink);
      background:
        radial-gradient(circle at 8% 5%, rgba(0, 169, 132, .14), transparent 28%),
        radial-gradient(circle at 95% 0%, rgba(124, 58, 237, .13), transparent 30%),
        linear-gradient(145deg, #f8fbff 0%, #eef6ff 44%, #fbfdff 100%);
    }

    button, input { font: inherit; }
    button {
      border: 0;
      cursor: pointer;
      color: inherit;
    }

    .app {
      width: min(1500px, calc(100vw - 18px));
      height: calc(100dvh - 18px);
      margin: 9px auto;
      padding: clamp(10px, 1vw, 16px);
      border: 1px solid rgba(119, 151, 209, .38);
      border-radius: 22px;
      background: rgba(255,255,255,.78);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
      display: grid;
      grid-template-rows: auto auto auto auto minmax(0, 1fr) auto;
      gap: clamp(8px, 1vh, 12px);
      overflow: hidden;
    }

    .topbar, .center-nav, .brand, .actions, .mode-tabs, .exercise-title,
    .parent-grid, .info-strip, .workspace, .panel-head, .result-row,
    .bottom-bar, .stat-line, .cell-status {
      display: flex;
      align-items: center;
    }

    .topbar {
      justify-content: space-between;
      gap: 12px;
      min-height: 46px;
    }

    .brand { gap: 10px; min-width: 270px; }
    .dna {
      width: 30px;
      height: 42px;
      display: grid;
      place-items: center;
      color: var(--teal);
    }
    .brand h1 {
      margin: 0;
      font-size: clamp(1.25rem, 1.8vw, 1.8rem);
      line-height: 1;
      letter-spacing: 0;
    }
    .brand p {
      margin: 3px 0 0;
      color: #1264e3;
      font-weight: 700;
      font-size: .95rem;
    }

    .icon-btn, .nav-btn {
      width: clamp(38px, 4.8vh, 48px);
      height: clamp(38px, 4.8vh, 48px);
      border: 1px solid var(--line);
      border-radius: 999px;
      background: #fff;
      display: grid;
      place-items: center;
      color: #24406f;
      transition: transform .16s ease, border-color .16s ease, background .16s ease;
    }
    .icon-btn:hover, .nav-btn:hover { transform: translateY(-1px); border-color: #9db9ec; }
    .icon-btn svg, .nav-btn svg, .btn svg { width: 22px; height: 22px; }

    .center-nav { gap: 10px; justify-content: center; flex: 1; }
    .counter {
      min-width: 220px;
      height: clamp(38px, 4.8vh, 48px);
      padding: 0 24px;
      display: grid;
      place-items: center;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fff;
      font-weight: 800;
    }

    .actions { gap: 10px; justify-content: flex-end; min-width: 330px; }
    .language-select {
      min-height: clamp(38px, 4.8vh, 48px);
      padding: 0 12px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fff;
      color: var(--ink);
      font-weight: 850;
      outline: none;
    }
    .language-select:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(34,118,243,.12);
    }
    .mode-tabs {
      padding: 5px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: #fff;
      gap: 4px;
    }
    .mode-tabs button {
      min-width: 112px;
      padding: 8px 12px;
      border-radius: 999px;
      background: transparent;
      color: var(--muted);
      font-weight: 800;
    }
    .mode-tabs button.active {
      color: #fff;
      background: linear-gradient(135deg, #138cf5, #7048f1);
    }

    .btn {
      min-height: clamp(38px, 4.8vh, 48px);
      border-radius: var(--radius);
      padding: 0 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-weight: 850;
      background: #fff;
      border: 1px solid var(--line);
      color: #28426f;
      white-space: nowrap;
    }
    .btn.primary {
      color: #fff;
      border-color: transparent;
      background: linear-gradient(135deg, #16a7f5, #1766f1);
      box-shadow: 0 10px 24px rgba(23, 102, 241, .22);
    }
    .btn.purple {
      color: #fff;
      border-color: transparent;
      background: linear-gradient(135deg, #7c3aed, #9b4df3);
      box-shadow: 0 10px 24px rgba(124, 58, 237, .24);
    }
    .btn:disabled { opacity: .6; cursor: default; }

    .exercise-title {
      gap: 12px;
      padding: clamp(10px, 1.2vh, 14px);
      border: 1px solid var(--line);
      border-radius: 16px;
      background: rgba(255,255,255,.82);
      min-height: clamp(72px, 10vh, 104px);
    }
    .badge-art {
      width: clamp(48px, 6.8vh, 64px);
      height: clamp(48px, 6.8vh, 64px);
      flex: 0 0 clamp(48px, 6.8vh, 64px);
      border-radius: 50%;
      display: grid;
      place-items: center;
      color: #fff;
      background: linear-gradient(135deg, var(--teal), #08c18e);
      box-shadow: inset 0 -12px 24px rgba(0,0,0,.12);
    }
    .exercise-title h2 {
      margin: 0;
      font-size: clamp(1.35rem, 2.2vw, 2.05rem);
      line-height: 1.12;
      letter-spacing: 0;
    }
    .exercise-title p {
      margin: 4px 0 0;
      color: var(--muted);
      font-weight: 750;
      font-size: clamp(.95rem, 1.2vw, 1.16rem);
    }
    .exercise-title strong { color: var(--ink); }

    .parent-grid {
      align-items: stretch;
      gap: 12px;
      min-height: 0;
    }
    .parent-card {
      flex: 1;
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: clamp(10px, 1.2vh, 14px);
      background: linear-gradient(135deg, rgba(255,255,255,.96), rgba(246,252,249,.92));
      overflow: hidden;
      min-width: 0;
    }
    .parent-card.b {
      background: linear-gradient(135deg, rgba(255,255,255,.96), rgba(249,246,255,.92));
    }
    .parent-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: clamp(6px, .8vh, 10px);
      color: var(--good);
      font-size: clamp(1rem, 1.2vw, 1.14rem);
      font-weight: 900;
    }
    .parent-card.b .parent-head { color: var(--violet); }
    .sex-symbol {
      width: clamp(32px, 4.8vh, 42px);
      height: clamp(32px, 4.8vh, 42px);
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: rgba(0,169,132,.13);
    }
    .parent-card.b .sex-symbol { background: rgba(124,58,237,.13); }
    .parent-content {
      display: grid;
      grid-template-columns: minmax(190px, 31%) 1fr;
      gap: 10px;
      align-items: stretch;
    }
    .organism {
      height: clamp(112px, 15.5vh, 185px);
      min-height: 0;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid rgba(16,38,87,.09);
      background: #eaf1f8;
      position: relative;
    }
    .organism img {
      width: 100%;
      height: 100%;
      display: block;
      min-height: 0;
      object-fit: cover;
    }
    .image-chip {
      position: absolute;
      left: 10px;
      bottom: 10px;
      max-width: calc(100% - 20px);
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,.86);
      color: var(--ink);
      box-shadow: 0 10px 24px rgba(16,38,87,.16);
      font-size: clamp(.72rem, .8vw, .82rem);
      font-weight: 850;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      backdrop-filter: blur(8px);
    }
    .facts {
      display: grid;
      gap: clamp(5px, .7vh, 8px);
      align-content: center;
    }
    .fact, .allele-note {
      min-height: clamp(28px, 4vh, 38px);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 5px 10px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: rgba(255,255,255,.72);
      font-size: clamp(.76rem, .86vw, .96rem);
    }
    .fact span:first-child {
      color: var(--ink);
      font-weight: 650;
    }
    .fact strong {
      color: var(--good);
      text-align: right;
      min-width: 0;
      line-height: 1.15;
      overflow-wrap: anywhere;
    }
    .parent-card.b .fact strong { color: var(--violet); }
    .allele-note {
      justify-content: flex-start;
      color: var(--good);
      font-weight: 850;
      background: rgba(16,161,93,.08);
      white-space: normal;
      overflow: visible;
      text-overflow: clip;
      line-height: 1.12;
      font-size: clamp(.64rem, .74vw, .84rem);
    }
    .parent-card.b .allele-note {
      color: var(--violet);
      background: rgba(124,58,237,.09);
    }

    .info-strip {
      gap: 10px;
      padding: 9px 14px;
      border-radius: 14px;
      border: 1px solid #b7d8ff;
      background: linear-gradient(135deg, rgba(239,248,255,.92), rgba(245,252,255,.98));
      color: var(--ink);
      font-size: clamp(.9rem, 1vw, 1.02rem);
      min-height: clamp(38px, 5.2vh, 52px);
    }
    .info-strip svg { color: var(--blue); flex: 0 0 auto; }

    .workspace {
      align-items: stretch;
      gap: 12px;
      min-height: 0;
    }
    .panel {
      flex: 1;
      min-width: 0;
      padding: clamp(10px, 1.1vh, 14px);
      border: 1px solid var(--line);
      border-radius: 16px;
      background: rgba(255,255,255,.86);
      display: flex;
      flex-direction: column;
      min-height: 0;
      overflow: hidden;
    }
    .panel-head {
      gap: 10px;
      margin-bottom: 8px;
      flex: 0 0 auto;
    }
    .panel-head h3 {
      margin: 0;
      font-size: clamp(1rem, 1.2vw, 1.22rem);
      letter-spacing: 0;
    }
    .panel-head svg { color: var(--blue); }

    .punnett-wrap {
      overflow: hidden;
      padding: 0;
      flex: 1;
      min-height: 0;
      display: flex;
    }
    .punnett {
      display: grid;
      gap: 0;
      width: 100%;
      height: 100%;
      min-width: 0;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid var(--line);
      background: #fff;
    }
    .p-cell {
      min-height: 0;
      display: grid;
      place-items: center;
      padding: 5px;
      border-right: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      text-align: center;
      font-weight: 850;
      min-width: 0;
    }
    .corner {
      background: linear-gradient(135deg, rgba(16,161,93,.09), rgba(124,58,237,.09));
      color: var(--muted);
      font-size: clamp(.7rem, .8vw, .86rem);
      line-height: 1.25;
    }
    .top-gamete {
      color: #5b35d5;
      background: rgba(124,58,237,.09);
      font-size: clamp(.9rem, 1.2vw, 1.08rem);
    }
    .side-gamete {
      color: var(--good);
      background: rgba(16,161,93,.09);
      font-size: clamp(.9rem, 1.2vw, 1.08rem);
    }
    .answer-cell {
      background: #fff;
      position: relative;
    }
    .answer-cell input {
      width: 100%;
      height: min(42px, 72%);
      border: 1px dashed #b9c8de;
      border-radius: var(--radius);
      text-align: center;
      color: var(--ink);
      font-weight: 800;
      outline: none;
      background: #fff;
    }
    .answer-cell input:focus {
      border-color: var(--teal);
      box-shadow: 0 0 0 3px rgba(0,169,132,.14);
    }
    .answer-cell.ok input { border-color: var(--good); background: rgba(16,161,93,.08); }
    .answer-cell.no input { border-color: var(--bad); background: rgba(220,53,69,.08); }

    .results {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, .85fr);
      grid-template-rows: minmax(0, 1fr) auto auto;
      grid-template-areas:
        "geno pheno"
        "actions actions"
        "feedback feedback";
      align-content: start;
      gap: 6px;
      min-height: 0;
      flex: 1;
    }
    .result-box {
      padding: 4px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,.78);
      min-height: 0;
      overflow: hidden;
    }
    .result-box:first-child { grid-area: geno; }
    .result-box:nth-child(2) { grid-area: pheno; }
    .result-box h4 {
      margin: 0 0 2px;
      font-size: clamp(.68rem, .76vw, .86rem);
    }
    .result-grid {
      display: grid;
      gap: 3px;
      min-height: 0;
      overflow: hidden;
    }
    .result-grid.genotypes {
      grid-template-columns: repeat(auto-fit, minmax(88px, 1fr));
    }
    .result-grid:not(.genotypes) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .result-row {
      min-height: clamp(20px, 2.5vh, 28px);
      gap: 4px;
      justify-content: space-between;
      padding: 1px 5px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: linear-gradient(135deg, rgba(16,161,93,.06), rgba(124,58,237,.05));
      font-size: clamp(.64rem, .72vw, .82rem);
    }
    .result-row label {
      font-weight: 850;
      color: var(--ink);
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .result-grid.genotypes .result-row label {
      flex: 0 0 clamp(34px, 2.35vw, 42px);
    }
    .result-grid:not(.genotypes) .result-row label {
      white-space: normal;
      text-overflow: clip;
      line-height: 1.12;
      font-size: clamp(.6rem, .7vw, .8rem);
    }
    .result-row input {
      width: clamp(34px, 3.15vw, 52px);
      height: clamp(18px, 2.2vh, 24px);
      border: 1px solid #c9d6eb;
      border-radius: var(--radius);
      text-align: center;
      outline: none;
      font-weight: 800;
      color: var(--ink);
      background: #fff;
    }
    .result-row span {
      display: flex;
      align-items: center;
      gap: 2px;
      flex: 0 0 auto;
      white-space: nowrap;
    }
    .result-row input:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(34,118,243,.12);
    }
    .result-row.ok { border-color: rgba(16,161,93,.55); background: rgba(16,161,93,.08); }
    .result-row.no { border-color: rgba(220,53,69,.45); background: rgba(220,53,69,.07); }

    .result-actions {
      grid-area: actions;
      display: grid;
      grid-template-columns: 1fr minmax(112px, 140px);
      gap: 6px;
      flex: 0 0 auto;
    }
    .result-actions .btn {
      min-height: clamp(30px, 4vh, 36px);
      font-size: clamp(.78rem, .9vw, .95rem);
    }
    .feedback {
      grid-area: feedback;
      min-height: clamp(24px, 3.5vh, 40px);
      padding: 5px 8px;
      border-radius: var(--radius);
      background: var(--soft);
      color: var(--muted);
      font-weight: 720;
      line-height: 1.25;
      font-size: clamp(.74rem, .86vw, .94rem);
      display: flex;
      align-items: center;
    }
    .feedback.good { color: var(--good); background: rgba(16,161,93,.09); }
    .feedback.bad { color: #b42335; background: rgba(220,53,69,.08); }

    .bottom-bar {
      justify-content: space-between;
      gap: 12px;
      padding: 8px 14px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: rgba(255,255,255,.74);
      color: var(--muted);
      font-weight: 750;
      min-height: 38px;
    }
    .stat-line { gap: 8px; }
    .credit-footer {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
      padding: 6px 10px;
      border: 1px solid rgba(34,118,243,.18);
      border-radius: 999px;
      background: rgba(255,255,255,.76);
      color: var(--ink);
      font-size: clamp(.76rem, .85vw, .92rem);
      font-weight: 850;
    }
    .credit-footer span {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .credit-close {
      width: 22px;
      height: 22px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--muted);
      font-weight: 900;
      line-height: 1;
      flex: 0 0 auto;
    }
    .progress {
      width: min(360px, 34vw);
      height: 10px;
      border-radius: 999px;
      background: #dfe7f3;
      overflow: hidden;
    }
    .bar {
      width: 0%;
      height: 100%;
      background: linear-gradient(90deg, var(--teal), var(--blue));
      transition: width .28s ease;
    }

    .tiny { font-size: .78rem; color: var(--muted); }
    .hide { display: none !important; }

    @media (max-height: 760px) and (min-width: 721px) {
      .app { padding: 8px; gap: 6px; }
      .exercise-title { min-height: 62px; padding: 8px 10px; }
      .badge-art { width: 46px; height: 46px; flex-basis: 46px; }
      .exercise-title h2 { font-size: clamp(1.2rem, 1.9vw, 1.7rem); }
      .parent-card { padding: 8px; }
      .parent-head { margin-bottom: 4px; font-size: clamp(.9rem, 1vw, 1.02rem); }
      .parent-content { gap: 8px; grid-template-columns: minmax(170px, 30%) 1fr; }
      .organism { height: clamp(96px, 14vh, 140px); }
      .facts { gap: 4px; }
      .fact, .allele-note { min-height: 24px; padding: 3px 8px; font-size: clamp(.64rem, .72vw, .82rem); }
      .info-strip { min-height: 34px; padding: 6px 12px; font-size: clamp(.82rem, .92vw, .94rem); }
      .panel { padding: 8px; }
      .panel-head { margin-bottom: 5px; }
      .panel-head h3 { font-size: clamp(.94rem, 1.05vw, 1.08rem); }
      .result-actions .btn { min-height: 26px; }
      .feedback { min-height: 20px; padding: 3px 7px; font-size: clamp(.66rem, .76vw, .8rem); }
      .bottom-bar { padding: 4px 10px; min-height: 34px; }
      .credit-footer { padding: 3px 7px; font-size: clamp(.66rem, .76vw, .82rem); }
      .credit-close { width: 18px; height: 18px; }
      .progress { height: 8px; }
    }

    @media (max-width: 1140px) {
      .topbar { flex-wrap: wrap; }
      .brand, .actions { min-width: 0; }
      .center-nav { order: 3; width: 100%; }
      .parent-grid, .workspace { flex-direction: column; }
    }
    @media (max-width: 720px) {
      .app { width: min(100% - 10px, 100%); margin: 5px auto; padding: 12px; border-radius: 16px; }
      .topbar { align-items: flex-start; }
      .brand { width: 100%; }
      .actions { width: 100%; flex-wrap: wrap; justify-content: stretch; }
      .mode-tabs { width: 100%; }
      .mode-tabs button { flex: 1; min-width: 0; }
      .actions .btn { flex: 1; }
      .language-select { flex: 0 0 92px; }
      .counter { min-width: 170px; flex: 1; }
      .parent-content { grid-template-columns: 1fr; }
      .organism { min-height: 180px; }
      .exercise-title { align-items: flex-start; }
      .badge-art { width: 52px; height: 52px; flex-basis: 52px; }
      .result-actions { grid-template-columns: 1fr; }
      .bottom-bar { flex-direction: column; align-items: flex-start; }
      .credit-footer { width: 100%; justify-content: space-between; }
      .progress { width: 100%; }
    }
  </style>
</head>
<body>
  <main class="app">
    <header class="topbar">
      <div class="brand">
        <button class="icon-btn" id="resetBtn" title="Reiniciar respuestas" aria-label="Reiniciar respuestas">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v6h6"/></svg>
        </button>
        <div class="dna" aria-hidden="true">
          <svg viewBox="0 0 40 54" fill="none" stroke="currentColor" stroke-width="3">
            <path d="M10 3c22 12 22 36 0 48"/><path d="M30 3C8 15 8 39 30 51"/>
            <path d="M13 12h14M10 22h20M10 32h20M13 42h14"/>
          </svg>
